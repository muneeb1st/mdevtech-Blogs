{
  "name": "mdevtech-blogs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Autonomous SEO-first blog powered by Hermes Agent, Supabase, and Vercel.",
  "scripts": {
    "generate": "node src/generator.mjs",
    "generate:strict": "STRICT_SEO=1 node src/generator.mjs --strict",
    "build": "node src/build.mjs",
    "build:strict": "STRICT_SEO=1 node src/build.mjs",
    "dev": "node src/server.mjs",
    "audit:seo": "node scripts/audit-seo.mjs",
    "audit:seo:strict": "STRICT_SEO=1 node scripts/audit-seo.mjs --strict",
    "preview:seo": "npm run build && npm run audit:seo"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "dotenv": "^17.4.2"
  }
}
