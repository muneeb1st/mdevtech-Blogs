# AWS/Linux cron example.
# Run from `crontab -e` after replacing the repo path if needed.
# This script pulls latest main, runs Hermes generation, strict build/audit,
# commits changed content/public output, and pushes to GitHub for Vercel deploy.

0 */12 * * * MDEVTECH_REPO_DIR=/home/ubuntu/mdevtech-Blogs /bin/bash /home/ubuntu/mdevtech-Blogs/automation/run-aws-cron.sh
