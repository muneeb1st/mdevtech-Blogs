# Local development environment variables.
# Do not commit real secrets.

SITE_URL=http://localhost:4173

# Supabase durable backup/restore
# Required for npm run supabase:backup / supabase:restore.
# Use the service-role key only on trusted servers. Never expose it in browser code.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Google Analytics / Search Console
# Set GOOGLE_TAG_ID to your GA4 Measurement ID, such as G-XXXXXXXXXX.
GOOGLE_TAG_ID=
GOOGLE_ANALYTICS_ID=
GOOGLE_SITE_VERIFICATION=
GSC_VERIFICATION=

# Hermes
HERMES_CLI_PATH=
HERMES_MODEL=
HERMES_PROVIDER=
HERMES_SKILLS=
HERMES_TOOLSETS=
HERMES_TIMEOUT_MS=600000
HERMES_ACCEPT_HOOKS=

# SEO Quality (set STRICT_SEO=1 to block weak posts instead of warning)
STRICT_SEO=0
PREFER_LOW_DIFFICULTY_KEYWORDS=1
